{
  "manifest_version": 2,
  "name": "Search NoAI",
  "version": "1.0",
  "description": "An extension for disabling the AI Overview on all Google searches by appending -noai to the search.",
  "permissions": [
    "*://*.google.com/*",
    "*://google.com/*",
    "tabs",
    "webRequest",
    "webRequestBlocking"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "search-noai@factorial"
    }
  },
  "background": {
    "scripts": ["noai.js"]
  }
}